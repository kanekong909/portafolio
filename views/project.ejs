<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= project.title %> — Portfolio
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>

<body>
  <div class="noise"></div>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-dot" id="cursorDot"></div>

  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo"><span class="logo-bracket">[</span>dev<span class="logo-bracket">]</span></a>
      <nav class="nav">
        <a href="/#proyectos" class="nav-link">Proyectos</a>
        <a href="/#sobre-mi" class="nav-link">Sobre mí</a>
        <a href="/#contacto" class="nav-link">Contacto</a>
      </nav>
      <a href="/admin" class="admin-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
        </svg>
        Admin
      </a>
    </div>
  </header>

  <main class="project-detail">
    <div class="pd-back">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Volver al portfolio
      </a>
    </div>

    <div class="pd-hero">
      <div class="pd-meta">
        <div class="pd-tags">
          <% if (project.tags) { project.tags.split(',').forEach(tag=> { %>
            <span class="tag">
              <%= tag.trim() %>
            </span>
            <% })} %>
        </div>
        <% if (project.featured) { %>
          <div class="pd-featured-badge">★ Proyecto Destacado</div>
          <% } %>
      </div>
      <h1 class="pd-title">
        <%= project.title %>
      </h1>
      <p class="pd-desc">
        <%= project.description %>
      </p>
      <div class="pd-actions">
        <% if (project.liveUrl) { %>
          <a href="<%= project.liveUrl %>" target="_blank" class="btn-primary">
            Ver en vivo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
          <% } %>
            <% if (project.githubUrl) { %>
              <a href="<%= project.githubUrl %>" target="_blank" class="btn-ghost">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </a>
              <% } %>
      </div>
    </div>

    <% const imgs=JSON.parse(project.images || '[]' ); %>
      <% if (imgs.length> 0) { %>
        <div class="carousel">
          <div class="carousel-track" id="carouselTrack">
            <% imgs.forEach((img, i)=> { %>
              <div class="carousel-slide">
                <img src="<%= img %>" alt="<%= project.title %> — imagen <%= i+1 %>">
              </div>
              <% }) %>
          </div>
          <% if (imgs.length> 1) { %>
            <button class="carousel-btn carousel-prev" id="carouselPrev">‹</button>
            <button class="carousel-btn carousel-next" id="carouselNext">›</button>
            <div class="carousel-dots" id="carouselDots">
              <% imgs.forEach((_, i)=> { %>
                <button class="carousel-dot <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>"></button>
                <% }) %>
            </div>
            <% } %>
        </div>
        <% } %>

          <% if (project.longDescription) { %>
            <div class="pd-content">
              <div class="section-label">// descripción</div>
              <div class="pd-long-desc"><%- project.longDescription.replace(/\n/g, '<br>' ) %></div>
            </div>
            <% } %>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">[dev]</span>
      <span class="footer-copy">© <%= new Date().getFullYear() %> — Portfolio</span>
      <a href="/admin" class="footer-admin">Panel admin</a>
    </div>
  </footer>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">✕</button>
    <button class="lightbox-prev" id="lightboxPrev">‹</button>
    <img src="" alt="" class="lightbox-img" id="lightboxImg">
    <button class="lightbox-next" id="lightboxNext">›</button>
    <div class="lightbox-counter" id="lightboxCounter"></div>
  </div>

  <script src="/js/main.js"></script>
</body>

</html>